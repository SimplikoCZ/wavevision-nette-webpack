{
  "extends": "./tsconfig.json",
  "exclude": [
    "./*.js",
    "./examples/**/*",
    "./src/assets/**/tests/**/*",
    "./tests/**/*"
  ],
  "compilerOptions": {
    "allowJs": false,
    "declaration": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "outDir": "./dist",
    "resolveJsonModule": false
  }
}