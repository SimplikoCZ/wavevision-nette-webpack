{
  "name": "wavevision/nette-webpack",
  "description": "Webpack adapter for Nette framework.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Wavevision s.r.o",
      "email": "info@wavevision.com"
    },
    {
      "name": "Vít Rozsíval",
      "email": "vit@wavevision.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Wavevision\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Wavevision\\": "tests",
      "Wavevision\\NetteWebpackExamples\\": "examples/NetteWebpackExamples"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "phpstan/extension-installer": true
    }
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/SimplikoCZ/wavevision-props-control.git"
    },
    {
      "type": "vcs",
      "url": "https://github.com/SimplikoCZ/wavevision-utils.git"
    },
    {
      "type": "vcs",
      "url": "https://github.com/SimplikoCZ/wavevision-di-service-annotation"
    },
    {
      "type": "vcs",
      "url": "https://github.com/SimplikoCZ/wavevision-nette-tests.git"
    },
    {
      "type": "vcs",
      "url": "https://github.com/SimplikoCZ/wavevision-coding-standard.git"
    }
  ],
  "require": {
    "php": "^8.4",
    "latte/latte": "^3.0",
    "nette/di": "^3.0",
    "nette/http": "^3.0",
    "tracy/tracy": "^2.11",
    "wavevision/props-control": "^7.0",
    "wavevision/utils": "^3.0"
  },
  "require-dev": {
    "nette/application": "^3.0",
    "php-coveralls/php-coveralls": "^2.5",
    "phpstan/extension-installer": "^1.3",
    "phpstan/phpstan-nette": "^2.0",
    "wavevision/coding-standard": "^7.0",
    "wavevision/di-service-annotation": "^5.0",
    "wavevision/nette-tests": "^4.0"
  },
  "extra": {
    "phpstan": {}
  }
}
